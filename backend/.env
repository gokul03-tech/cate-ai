# =============================================================================
# LexOrch-KG — Environment Variables Template
# Copy this to .env and fill in your values
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=LexOrch-KG
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./lexorch.db

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexorch_neo4j

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_COLLECTION_NAME=legal_documents

# ── LLM Providers ────────────────────────────────────────────────────────────
# Groq (Primary — get free key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-70b-8192

# OpenAI (Optional fallback)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Ollama (Optional local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LLM Provider selection: groq | openai | ollama
LLM_PROVIDER=groq

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# ── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt

# ── Reports ────────────────────────────────────────────────────────────────────
REPORTS_DIR=reports

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@lexorch.ai
ADMIN_PASSWORD=AdminLex@2024
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
